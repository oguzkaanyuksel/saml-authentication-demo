<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <title><%= title %> – SAML Auth Demo</title>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #f0f4f8; display: flex; flex-direction: column;
      align-items: center; justify-content: center; min-height: 100vh; padding: 2rem;
    }
    .card {
      background: #fff; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,.1);
      max-width: 480px; width: 100%; padding: 2.5rem; text-align: center;
    }
    .icon { font-size: 3rem; margin-bottom: 1rem; }
    h1 { color: #c53030; margin-bottom: .75rem; }
    p  { color: #718096; line-height: 1.6; margin-bottom: 1.5rem; }
    a  {
      display: inline-block; padding: .65rem 1.5rem;
      background: #4299e1; color: #fff; border-radius: 6px;
      text-decoration: none; font-weight: 600;
    }
    a:hover { background: #3182ce; }
  </style>
</head>
<body>
  <div class="card">
    <div class="icon">❌</div>
    <h1><%= title %></h1>
    <p><%= message %></p>
    <a href="/">Ana Sayfaya Dön</a>
  </div>
</body>
</html>
